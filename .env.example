# =============================================================================
# LLMVault — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables are required unless noted otherwise.
# =============================================================================

# --- Environment ---
ENVIRONMENT=development                  # "development" or "production"

# --- Server ---
PORT=8080
LOG_LEVEL=info                        # debug, info, warn, error
LOG_FORMAT=json                       # json, text

# --- PostgreSQL ---
POSTGRES_USER=llmvault
POSTGRES_PASSWORD=                    # set a strong password
POSTGRES_DB=llmvault
POSTGRES_PORT=5433                    # host port mapped to container 5432
DB_HOST=localhost
DB_PORT=5433
DB_USER=llmvault
DB_PASSWORD=                          # same as POSTGRES_PASSWORD
DB_NAME=llmvault
DB_SSLMODE=disable                    # disable for dev, require for prod

# --- KMS (key wrapping for credential encryption) ---
KMS_TYPE=aead                         # "aead" for dev/single-node, "awskms" for AWS, "vault" for HashiCorp Vault
KMS_KEY=                              # base64-encoded 32-byte key (aead) or AWS KMS key ID/ARN (awskms) or Vault key name (vault)
AWS_REGION=                           # AWS region for awskms (e.g. us-east-1)

# --- HashiCorp Vault (for KMS_TYPE=vault) ---
VAULT_ADDRESS=http://localhost:8200   # Vault server URL
VAULT_TOKEN=llmvault-dev-token        # Vault authentication token (dev token for local dev)
VAULT_NAMESPACE=                      # Optional Vault Enterprise namespace
VAULT_MOUNT_PATH=transit              # Transit engine mount path
VAULT_CA_CERT=                        # Path to CA certificate (optional, for TLS)
VAULT_CLIENT_CERT=                    # Path to client certificate (optional, for TLS)
VAULT_CLIENT_KEY=                     # Path to client key (optional, for TLS)

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=                       # optional
REDIS_DB=0
REDIS_CACHE_TTL=30m

# --- L1 Cache (in-memory) ---
MEM_CACHE_TTL=5m
MEM_CACHE_MAX_SIZE=10000

# --- JWT ---
JWT_SIGNING_KEY=                      # HMAC-SHA256 signing key for sandbox tokens

# --- CORS ---
CORS_ORIGINS=http://localhost:30112   # comma-separated list of allowed origins

# --- ZITADEL ---
ZITADEL_MASTERKEY=                    # must be exactly 32 characters
ZITADEL_DB_PASSWORD=                  # password for the zitadel Postgres user
ZITADEL_DOMAIN=http://localhost:8085
ZITADEL_EXTERNALDOMAIN=localhost      # ZITADEL's external domain (used as Host header)
ZITADEL_EXTERNAL_URL=http://localhost:8085  # public-facing ZITADEL URL (issuer)
ZITADEL_INTERNAL_URL=http://zitadel:8080    # internal Docker network URL
ZITADEL_DEV_MODE=true                 # set to false in production
ZITADEL_ADMIN_PAT=                    # admin PAT (read from bootstrap/admin.pat in dev)
ZITADEL_PROJECT_ID=                   # project ID (read from bootstrap/api-credentials.json in dev)

# --- ZITADEL client (auto-populated by zitadel-init, or set manually) ---
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=

# --- Dashboard OIDC ---
DASHBOARD_REDIRECT_URI=http://localhost:30112/api/auth/callback/zitadel
DASHBOARD_LOGOUT_URI=http://localhost:30112

# --- Frontend (Next.js) auth ---
# NEXTAUTH_URL=http://localhost:30112
# NEXTAUTH_SECRET=                        # generate with: openssl rand -hex 32
# AUTH_ZITADEL_ID=                         # dashboard OIDC client ID (from zitadel-init)
# AUTH_ZITADEL_ISSUER=http://localhost:8085

# --- E2E test keys (only needed for e2e tests) ---
# OPENROUTER_API_KEY=sk-or-...
# FIREWORKS_API_KEY=fw_...
