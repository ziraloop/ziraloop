{
  "github": {
    "display_name": "GitHub",
    "resources": {
      "repo": {
        "display_name": "Repositories",
        "description": "GitHub repositories the AI can access",
        "id_field": "full_name",
        "name_field": "name",
        "icon": "repo",
        "list_action": "/installation/repositories",
        "request_config": {
          "method": "GET",
          "query_params": {
            "per_page": "100"
          },
          "response_path": "repositories"
        }
      }
    }
  },
  "slack": {
    "display_name": "Slack",
    "resources": {
      "channel": {
        "display_name": "Channels",
        "description": "Slack channels the AI can access",
        "id_field": "id",
        "name_field": "name_normalized",
        "icon": "hash",
        "list_action": "/conversations.list",
        "request_config": {
          "method": "GET",
          "query_params": {
            "types": "public_channel,private_channel",
            "exclude_archived": "true",
            "limit": "1000"
          },
          "response_path": "channels"
        }
      }
    }
  },
  "google_drive": {
    "display_name": "Google Drive",
    "resources": {
      "folder": {
        "display_name": "Folders",
        "description": "Folders the AI can access files within",
        "id_field": "id",
        "name_field": "name",
        "icon": "folder",
        "list_action": "/drive/v3/files",
        "request_config": {
          "method": "GET",
          "query_params": {
            "q": "mimeType='application/vnd.google-apps.folder' and trashed=false",
            "spaces": "drive",
            "fields": "files(id,name)",
            "pageSize": "100"
          },
          "response_path": "files"
        }
      }
    }
  },
  "notion": {
    "display_name": "Notion",
    "resources": {
      "page": {
        "display_name": "Pages",
        "description": "Notion pages the AI can access",
        "id_field": "id",
        "name_field": "title",
        "icon": "page",
        "list_action": "/v1/search",
        "request_config": {
          "method": "POST",
          "headers": {
            "Notion-Version": "2022-06-28"
          },
          "body_template": {
            "filter": {
              "value": "page",
              "property": "object"
            },
            "page_size": 100
          },
          "response_path": "results"
        }
      },
      "database": {
        "display_name": "Databases",
        "description": "Notion databases the AI can query",
        "id_field": "id",
        "name_field": "title",
        "icon": "database",
        "list_action": "/v1/search",
        "request_config": {
          "method": "POST",
          "headers": {
            "Notion-Version": "2022-06-28"
          },
          "body_template": {
            "filter": {
              "value": "database",
              "property": "object"
            },
            "page_size": 100
          },
          "response_path": "results"
        }
      }
    }
  },
