  "schemas": {
    "railway_alert": {
      "type": "object",
      "description": "Railway webhook alert payload. Sourced from bzvstudio/railway-assistant types/railway.go and Railway official docs (docs.railway.com/observability/webhooks).",
      "properties": {
        "type": {
          "type": "string",
          "description": "The event type in Deployment.<state> format (e.g. Deployment.failed, Deployment.success, Deployment.crashed, Deployment.building, Deployment.deploying)"
        },
        "severity": {
          "type": "string",
          "description": "Alert severity level: ERROR, WARNING, INFO, or SUCCESS"
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp of when the event occurred"
        },
        "details": {
          "type": "object",
          "description": "Event-specific details including deployment and git information",
          "properties": {
            "id": {
              "type": "string",
              "description": "The deployment UUID"
            },
            "source": {
              "type": "string",
              "description": "The deploy source (e.g. GitHub)"
            },
            "status": {
              "type": "string",
              "description": "The deployment status string (e.g. SUCCESS, FAILED)"
            },
            "branch": {
              "type": "string",
              "description": "The git branch that triggered the deployment"
            },
            "commitHash": {
              "type": "string",
              "description": "The git commit SHA"
            },
            "repoSource": {
              "type": "string",
              "description": "The repository source identifier"
            },
            "commitAuthor": {
              "type": "string",
              "description": "The git commit author name"
            },
            "commitMessage": {
              "type": "string",
              "description": "The git commit message"
            }
          }
        },
        "resource": {
          "type": "object",
          "description": "Contextual resource identifiers for the event",
          "properties": {
            "workspace": {
              "type": "object",
              "description": "The Railway workspace",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Workspace UUID"
                },
                "name": {
                  "type": "string",
                  "description": "Workspace name"
                }
              }
            },
            "project": {
              "type": "object",
              "description": "The Railway project",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Project UUID"
                },
                "name": {
                  "type": "string",
                  "description": "Project name"
                }
              }
            },
            "environment": {
              "type": "object",
              "description": "The Railway environment",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Environment UUID"
                },
                "name": {
                  "type": "string",
                  "description": "Environment name (e.g. production, staging)"
                },
                "isEphemeral": {
                  "type": "boolean",
                  "description": "Whether this is an ephemeral environment (e.g. PR deploy)"
                }
              }
            },
            "service": {
              "type": "object",
              "description": "The Railway service. Nullable — omitted for non-deployment alerts (e.g. volume or monitor alerts)",
              "nullable": true,
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Service UUID"
                },
                "name": {
                  "type": "string",
                  "description": "Service name"
                }
              }
            },
            "deployment": {
              "type": "object",
              "description": "The Railway deployment. Nullable — omitted for non-deployment alerts",
              "nullable": true,
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Deployment UUID"
                }
              }
            }
          }
        }
      }
    }
  }
}
