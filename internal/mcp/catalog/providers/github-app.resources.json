{
  "provider": "github-app",
  "display_name": "GitHub",
  "description": "Subscribable resources for GitHub. An agent with the github-app integration can call subscribe_to_events with any of these resource_types to receive future webhook events on a specific resource.",
  "resources": {
    "github_issue": {
      "display_name": "GitHub Issue",
      "description": "Issue in a GitHub repository. Receives issue lifecycle and comment events.",
      "id_pattern": "^(?P<owner>[\\w.-]+)/(?P<repo>[\\w.-]+)#(?P<number>\\d+)$",
      "id_example": "ziraloop/ziraloop#42",
      "canonical_template": "github/{owner}/{repo}/issue/{number}",
      "events": [
        "issues.closed",
        "issues.reopened",
        "issues.edited",
        "issues.labeled",
        "issues.unlabeled",
        "issues.assigned",
        "issues.unassigned",
        "issues.milestoned",
        "issue_comment.created",
        "issue_comment.edited",
        "issue_comment.deleted"
      ]
    },
    "github_pull_request": {
      "display_name": "GitHub Pull Request",
      "description": "Pull request in a GitHub repository. Receives all PR lifecycle, review, review-comment, and CI events tied to this PR.",
      "id_pattern": "^(?P<owner>[\\w.-]+)/(?P<repo>[\\w.-]+)#(?P<number>\\d+)$",
      "id_example": "ziraloop/ziraloop#99",
      "canonical_template": "github/{owner}/{repo}/pull/{number}",
      "events": [
        "pull_request.closed",
        "pull_request.reopened",
        "pull_request.edited",
        "pull_request.synchronize",
        "pull_request.ready_for_review",
        "pull_request.converted_to_draft",
        "pull_request.labeled",
        "pull_request.unlabeled",
        "pull_request.assigned",
        "pull_request.review_requested",
        "pull_request.review_request_removed",
        "pull_request.auto_merge_enabled",
        "pull_request.auto_merge_disabled",
        "pull_request_review.submitted",
        "pull_request_review.dismissed",
        "pull_request_review.edited",
        "pull_request_review_comment.created",
        "pull_request_review_comment.edited",
        "pull_request_review_comment.deleted",
        "check_suite.completed",
        "check_suite.requested",
        "check_suite.rerequested",
        "check_run.completed",
        "check_run.created",
        "check_run.rerequested",
        "workflow_run.completed",
        "workflow_run.requested",
        "workflow_job.completed",
        "workflow_job.in_progress",
        "workflow_job.queued",
        "workflow_job.waiting",
        "issue_comment.created"
      ]
    },
    "github_discussion": {
      "display_name": "GitHub Discussion",
      "description": "Discussion thread in a GitHub repository. Receives discussion lifecycle and comment events.",
      "id_pattern": "^(?P<owner>[\\w.-]+)/(?P<repo>[\\w.-]+)#(?P<number>\\d+)$",
      "id_example": "ziraloop/ziraloop#14",
      "canonical_template": "github/{owner}/{repo}/discussion/{number}",
      "events": [
        "discussion.created",
        "discussion.edited",
        "discussion.answered",
        "discussion.labeled",
        "discussion_comment.created",
        "discussion_comment.edited",
        "discussion_comment.deleted"
      ]
    },
    "github_release": {
      "display_name": "GitHub Release",
      "description": "Release (tag) in a GitHub repository. Receives release lifecycle events.",
      "id_pattern": "^(?P<owner>[\\w.-]+)/(?P<repo>[\\w.-]+)@(?P<tag>[\\w.+-]+)$",
      "id_example": "ziraloop/ziraloop@v1.2.0",
      "canonical_template": "github/{owner}/{repo}/release/{tag}",
      "events": [
        "release.published",
        "release.released",
        "release.prereleased",
        "release.created",
        "release.edited"
      ]
    },
    "github_commit": {
      "display_name": "GitHub Commit",
      "description": "Events tied to a specific commit SHA. Use when no PR is linked (e.g. direct push to main). Both 7-char short SHAs and 40-char full SHAs are accepted — pick one and stick with it for stable routing.",
      "id_pattern": "^(?P<owner>[\\w.-]+)/(?P<repo>[\\w.-]+)@(?P<sha>[a-f0-9]{7,40})$",
      "id_example": "ziraloop/ziraloop@abc123d",
      "canonical_template": "github/{owner}/{repo}/commit/{sha}",
      "events": [
        "check_run.completed",
        "check_suite.completed",
        "deployment_status.created"
      ]
    },
    "github_branch": {
      "display_name": "GitHub Branch",
      "description": "Events on a specific branch: pushes, branch creation, branch deletion.",
      "id_pattern": "^(?P<owner>[\\w.-]+)/(?P<repo>[\\w.-]+):(?P<branch>[\\w./-]+)$",
      "id_example": "ziraloop/ziraloop:main",
      "canonical_template": "github/{owner}/{repo}/branch/{branch}",
      "events": [
        "push",
        "create",
        "delete"
      ]
    },
    "github_repository": {
      "display_name": "GitHub Repository",
      "description": "Repository-wide events: forks, stars, watchers. Use sparingly on popular repos — high event volume.",
      "id_pattern": "^(?P<owner>[\\w.-]+)/(?P<repo>[\\w.-]+)$",
      "id_example": "ziraloop/ziraloop",
      "canonical_template": "github/{owner}/{repo}",
      "events": [
        "fork",
        "star.created",
        "watch.started"
      ]
    }
  }
}
