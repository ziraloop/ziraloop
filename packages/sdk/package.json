{
  "name": "@llmvault/sdk",
  "version": "1.0.1",
  "description": "Server-side SDK for the LLMVault API",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "openapi-typescript ../../docs/openapi.json -o src/generated/schema.d.ts",
    "build": "npm run generate && tsup",
    "prepublish": "npm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "openapi-typescript": "^7.8.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
