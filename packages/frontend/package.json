{
  "name": "@ziraloop/frontend",
  "version": "1.0.6",
  "description": "Frontend SDK for embedding the ZiraLoop connect widget",
  "license": "O'Saasy",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "example": "vite serve example",
    "prepublish": "npm run build"
  },
  "devDependencies": {
    "@vitest/browser": "^4.1.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
